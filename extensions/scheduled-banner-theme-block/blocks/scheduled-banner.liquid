        </div>
        <div class="scheduled-banner__promo-body">
          {% if selected_promo_title != blank %}<h3 class="scheduled-banner__promo-title">{{ selected_promo_title }}</h3>{% endif %}
          {% if selected_promo_desc != blank %}<p class="scheduled-banner__promo-desc">{{ selected_promo_desc }}</p>{% endif %}
          {% if selected_promo_btn != blank %}<span class="scheduled-banner__button">{{ selected_promo_btn }}</span>{% endif %}
        </div>
      </div>
    </a>
  {% endif %}
</div>


