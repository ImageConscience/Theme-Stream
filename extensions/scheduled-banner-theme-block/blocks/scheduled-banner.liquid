{% if show_countdown %}
<script>
(function() {
  var wrap = document.getElementById('countdown-{{ block.id | default: "main" }}');
  var el = wrap ? wrap.querySelector('.scheduled-banner__countdown-timer') : document.querySelector('.scheduled-banner__countdown-timer[data-target="{{ selected_countdown_target }}"]');
  if (!el) return;
  var target = new Date('{{ selected_countdown_target }}').getTime();
  function update() {
    var now = Date.now();
    var diff = Math.max(0, target - now);
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    var days = el.querySelector('[data-days]');
    var hours = el.querySelector('[data-hours]');
    var mins = el.querySelector('[data-mins]');
    var secs = el.querySelector('[data-secs]');
    if (days) days.textContent = d;
    if (hours) hours.textContent = String(h).padStart(2,'0');
    if (mins) mins.textContent = String(m).padStart(2,'0');
    if (secs) secs.textContent = String(s).padStart(2,'0');
  }
  update();
  setInterval(update, 1000);
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Scheduled Block",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "position_id",
      "label": "Position Handle",
      "info": "Use the handle from Block Scheduler > Positions (e.g. homepage_banner). Copy from the app.",
      "default": "homepage_banner"
    },
    {
      "type": "number",
      "id": "breakpoint",
      "label": "Mobile Breakpoint (px)",
      "info": "Screen width below which mobile banner is shown",
      "default": 768
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom Margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ]
}
{% endschema %}

