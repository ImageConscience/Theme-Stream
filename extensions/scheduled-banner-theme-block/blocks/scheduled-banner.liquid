{% comment %}
  Universal Scheduled Block: Filter entries by position_id, block_type, and date/time range.
  Supports Hero and Announcement Bar types. If multiple matches, selects the one with most recent start_at.
{% endcomment %}

{% comment %} Store-owned metaobjects. Use metaobjects.type.values to loop all entries. {% endcomment %}
{% assign all_entries = metaobjects.schedulable_entity.values %}
{% assign position_id = block.settings.position_id | default: '' | strip %}
{% comment %} All block types allowed when scheduled for this position {% endcomment %}
{% assign now_ts = 'now' | date: '%s' | plus: 0 %}

{% assign latest_start_ts = 0 %}
{% assign selected_block_type = blank %}
{% assign selected_title = blank %}
{% assign selected_description = blank %}
{% assign selected_desktop_banner = blank %}
{% assign selected_mobile_banner = blank %}
{% assign selected_target_url = blank %}
{% assign selected_button_text = blank %}
{% assign selected_announcement_text = blank %}
{% assign selected_announcement_link = blank %}
{% assign selected_announcement_bg = blank %}
{% assign selected_announcement_color = blank %}
{% assign selected_collection_handle = blank %}
{% assign selected_collection_image = blank %}
{% assign selected_countdown_target = blank %}
{% assign selected_countdown_headline = blank %}
{% assign selected_countdown_subtext = blank %}
{% assign selected_countdown_bg_img = blank %}
{% assign selected_countdown_bg = blank %}
{% assign selected_countdown_text_color = blank %}
{% assign selected_countdown_link = blank %}
{% assign selected_countdown_btn = blank %}
{% assign selected_iwt_image = blank %}
{% assign selected_iwt_layout = blank %}
{% assign selected_video_url = blank %}
{% assign selected_video_file = blank %}
{% assign selected_video_file_ref = blank %}
{% assign selected_video_overlay = 50 %}
{% assign selected_promo_image = blank %}
{% assign selected_promo_title = blank %}
{% assign selected_promo_desc = blank %}
{% assign selected_promo_url = blank %}
{% assign selected_promo_btn = blank %}
{% assign selected_iwt_link = blank %}
{% assign selected_css_class = '' %}
{% assign selected_custom_css = '' %}
{% assign found_match = false %}

{% if all_entries != blank %}
  {% for entry in all_entries %}
    {% assign entry_pos = entry.position_id.value | default: entry.position_id | strip %}
    {% assign entry_block_type = entry.block_type | default: 'hero' | strip %}
    {% if entry_pos == position_id %}
      {% assign start_at_value = entry.start_at %}
      {% assign end_at_value = entry.end_at %}
      
      {% if start_at_value != blank and end_at_value != blank %}
        {% assign start_ts = start_at_value | date: '%s' | plus: 0 %}
        {% assign end_ts = end_at_value | date: '%s' | plus: 0 %}
        
        {% comment %} Check if current time is within the scheduled range: start_at <= NOW < end_at {% endcomment %}
        {% if now_ts >= start_ts and now_ts < end_ts %}
          {% if start_ts > latest_start_ts or latest_start_ts == 0 %}
            {% assign latest_start_ts = start_ts %}
            {% assign selected_block_type = entry_block_type %}
            {% assign tc_raw = entry.type_config | default: '' %}
            {% assign tc = blank %}
            {% if tc_raw != blank %}
              {% # theme-check-disable-next-line UnknownFilter %}
              {% assign tc = tc_raw | json_parse %}
            {% endif %}
            {% if tc != blank %}
              {% assign selected_title = tc.headline | default: entry.headline %}
              {% assign selected_description = tc.description | default: entry.description %}
              {% assign selected_desktop_banner = tc.desktop_banner | default: entry.desktop_banner %}
              {% assign selected_mobile_banner = tc.mobile_banner | default: entry.mobile_banner %}
              {% assign selected_target_url = tc.target_url | default: entry.target_url %}
              {% assign selected_button_text = tc.button_text | default: entry.button_text %}
              {% assign selected_announcement_text = tc.text %}
              {% assign selected_announcement_link = tc.link %}
              {% assign selected_announcement_bg = tc.bg_color | default: '#000000' %}
              {% assign selected_announcement_color = tc.text_color | default: '#ffffff' %}
              {% assign selected_collection_handle = tc.collection_handle %}
              {% if tc.image != blank %}{% assign selected_collection_image = entry.desktop_banner %}{% endif %}
              {% assign selected_countdown_target = tc.target_date %}
              {% assign selected_countdown_headline = tc.headline %}
              {% assign selected_countdown_subtext = tc.subtext %}
              {% if tc.background_image != blank %}{% assign selected_countdown_bg_img = entry.desktop_banner %}{% endif %}
              {% assign selected_countdown_bg = tc.background_color | default: '#000000' %}
              {% assign selected_countdown_text_color = tc.text_color | default: '#ffffff' %}
              {% assign selected_countdown_link = tc.target_url %}
              {% assign selected_countdown_btn = tc.button_text %}
              {% assign selected_iwt_image = entry.desktop_banner %}
              {% assign selected_iwt_layout = tc.layout | default: 'image_left' %}
              {% assign selected_iwt_link = tc.button_link %}
              {% assign selected_video_url = tc.video_url %}
              {% assign selected_video_file = tc.video_file %}
              {% if tc.video_file != blank %}{% assign selected_video_file_ref = entry.desktop_banner %}{% endif %}
              {% assign selected_video_overlay = tc.overlay_opacity | default: 50 %}
              {% assign selected_promo_image = entry.desktop_banner %}
              {% assign selected_promo_title = tc.title %}
              {% assign selected_promo_desc = tc.description %}
              {% assign selected_promo_url = tc.cta_url %}
              {% assign selected_promo_btn = tc.cta_text %}
              {% assign selected_iwt_link = tc.button_link %}
              {% assign selected_css_class = tc.css_class | default: '' %}
              {% assign selected_custom_css = tc.custom_css | default: '' %}
              {% assign selected_image_height = tc.image_height | default: 'adapt_to_image' %}
              {% assign selected_image_height_mobile = tc.image_height_mobile | default: 'adapt_to_image' %}
              {% assign selected_image_fit = tc.image_fit | default: 'cover' %}
              {% assign selected_image_fit_mobile = tc.image_fit_mobile | default: 'cover' %}
              {% assign selected_button_bg = tc.button_bg_color %}
              {% assign selected_button_text_color = tc.button_text_color %}
              {% assign selected_button_radius = tc.button_border_radius %}
              {% assign selected_button_padding_vertical = tc.button_padding_vertical %}
              {% assign selected_button_padding_horizontal = tc.button_padding_horizontal %}
              {% assign selected_button_padding = tc.button_padding %}
              {% assign selected_button_font_size = tc.button_font_size %}
              {% assign selected_headline_font_size = tc.headline_font_size %}
              {% assign selected_desc_font_size = tc.description_font_size %}
              {% assign selected_headline_color = tc.headline_color %}
              {% assign selected_desc_color = tc.description_color %}
              {% assign selected_text_alignment = tc.text_alignment %}
              {% assign selected_overlay_opacity = tc.overlay_opacity %}
              {% assign selected_overlay_color = tc.overlay_color %}
              {% assign selected_vertical_alignment = tc.vertical_alignment %}
              {% assign selected_mobile_content_below = tc.mobile_content_below %}
              {% assign selected_headline_color_below = tc.headline_color_below %}
              {% assign selected_desc_color_below = tc.description_color_below %}
              {% assign selected_button_bg_below = tc.button_bg_color_below %}
              {% assign selected_button_text_color_below = tc.button_text_color_below %}
            {% else %}
              {% assign selected_title = entry.headline %}
              {% assign selected_description = entry.description %}
              {% assign selected_desktop_banner = entry.desktop_banner %}
              {% assign selected_mobile_banner = entry.mobile_banner %}
              {% assign selected_target_url = entry.target_url %}
              {% assign selected_button_text = entry.button_text %}
              {% assign selected_css_class = '' %}
              {% assign selected_custom_css = '' %}
              {% assign selected_image_height = 'adapt_to_image' %}
              {% assign selected_image_height_mobile = 'adapt_to_image' %}
              {% assign selected_image_fit = 'cover' %}
              {% assign selected_image_fit_mobile = 'cover' %}
              {% assign selected_button_bg = blank %}
              {% assign selected_button_text_color = blank %}
              {% assign selected_button_radius = blank %}
              {% assign selected_button_padding_vertical = blank %}
              {% assign selected_button_padding_horizontal = blank %}
              {% assign selected_button_padding = blank %}
              {% assign selected_button_font_size = blank %}
              {% assign selected_headline_font_size = blank %}
              {% assign selected_desc_font_size = blank %}
              {% assign selected_headline_color = blank %}
              {% assign selected_desc_color = blank %}
              {% assign selected_text_alignment = blank %}
              {% assign selected_overlay_opacity = blank %}
              {% assign selected_overlay_color = blank %}
              {% assign selected_vertical_alignment = blank %}
              {% assign selected_mobile_content_below = blank %}
              {% assign selected_headline_color_below = blank %}
              {% assign selected_desc_color_below = blank %}
              {% assign selected_button_bg_below = blank %}
              {% assign selected_button_text_color_below = blank %}
            {% endif %}
            {% assign found_match = true %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign breakpoint = block.settings.breakpoint | default: 768 | plus: 0 %}
{% assign margin_top = block.settings.margin_top | default: 20 %}
{% assign margin_bottom = block.settings.margin_bottom | default: 20 %}

{% assign show_hero = false %}
{% assign show_announcement = false %}
{% assign show_collection = false %}
{% assign show_countdown = false %}
{% assign show_iwt = false %}
{% assign show_video = false %}
{% assign show_promo = false %}
{% if found_match %}
  {% if selected_block_type == 'hero' %}
    {% if selected_desktop_banner != blank or selected_mobile_banner != blank %}{% assign show_hero = true %}{% endif %}
  {% endif %}
  {% if selected_block_type == 'announcement_bar' and selected_announcement_text != blank %}{% assign show_announcement = true %}{% endif %}
  {% if selected_block_type == 'collection_banner' and selected_collection_handle != blank %}{% assign show_collection = true %}{% endif %}
  {% if selected_block_type == 'countdown_banner' and selected_countdown_target != blank %}{% assign show_countdown = true %}{% endif %}
  {% if selected_block_type == 'image_with_text' and selected_iwt_image != blank %}{% assign show_iwt = true %}{% endif %}
  {% if selected_block_type == 'background_video' %}
    {% if selected_video_url != blank or selected_video_file != blank %}{% assign show_video = true %}{% endif %}
  {% endif %}
  {% if selected_block_type == 'promo_card' and selected_promo_image != blank %}{% assign show_promo = true %}{% endif %}
{% endif %}
{% assign show_block = false %}
{% if show_hero or show_announcement or show_collection or show_countdown or show_iwt or show_video or show_promo %}{% assign show_block = true %}{% endif %}

{% assign img_height = selected_image_height | default: 'adapt_to_image' %}
{% assign img_height_m = selected_image_height_mobile | default: 'adapt_to_image' %}
{% comment %} adapt_to_image = exact proportions, width 100%, height from aspect ratio. Desktop and mobile operate independently. {% endcomment %}
{% if img_height == 'adapt_to_image' or img_height == 'adapt_to_width' %}{% assign banner_min_d = 'auto' %}{% elsif img_height == 'small' %}{% assign banner_min_d = '200px' %}{% elsif img_height == 'large' %}{% assign banner_min_d = '480px' %}{% elsif img_height == 'full_screen' %}{% assign banner_min_d = '100vh' %}{% else %}{% assign banner_min_d = '320px' %}{% endif %}
{% if img_height_m == 'adapt_to_image' or img_height_m == 'adapt_to_width' %}{% assign banner_min_m = 'auto' %}{% elsif img_height_m == 'small' %}{% assign banner_min_m = '180px' %}{% elsif img_height_m == 'large' %}{% assign banner_min_m = '360px' %}{% elsif img_height_m == 'full_screen' %}{% assign banner_min_m = '100vh' %}{% else %}{% assign banner_min_m = '280px' %}{% endif %}
{% assign img_fit_d = selected_image_fit | default: 'cover' %}
{% assign img_fit_m = selected_image_fit_mobile | default: 'cover' %}

{% if selected_custom_css != blank %}
<style>{{ selected_custom_css }}</style>
{% endif %}
<div class="scheduled-banner {{ selected_css_class }} {% unless show_block %}scheduled-banner--hidden{% endunless %}" style="margin-top: {{ margin_top }}px; margin-bottom: {{ margin_bottom }}px;" {{ block.shopify_attributes }}>
  {% if show_hero %}
    {% assign mobile_content_below = selected_mobile_content_below | default: false %}
    {% assign overlay_color = selected_overlay_color | default: '#000000' %}
    {% assign overlay_opacity_raw = selected_overlay_opacity | default: 70 %}
    {% assign overlay_opacity = overlay_opacity_raw | divided_by: 100.0 %}
    {% assign vertical_alignment = selected_vertical_alignment | default: 'bottom' %}
    {% assign content_alignment_desktop = selected_text_alignment | default: 'left' %}
    {% assign content_alignment_mobile = selected_text_alignment | default: 'left' %}
    {% assign button_padding_top = 12 %}
    {% assign button_padding_bottom = 12 %}
    {% assign button_padding_left = 30 %}
    {% assign button_padding_right = 30 %}
    {% assign headline_font_size = 2.5 %}
    {% assign title_font = blank %}
    {% assign description_font = blank %}
    {% assign description_font_size = 0.9 %}
    {% assign button_font_size = 1.0 %}
    {% assign button_border_radius = 6 %}
    {% assign title_color_overlay = '#ffffff' %}
    {% assign title_color_below = '#2c3e50' %}
    {% assign description_color_overlay = '#ffffff' %}
    {% assign description_color_below = '#666666' %}
    {% assign button_text_uppercase = false %}
    {% assign button_bg_overlay = '#ffffff' %}
    {% assign button_text_overlay = '#667eea' %}
    {% assign button_bg_below = '#667eea' %}
    {% assign button_text_below = '#ffffff' %}
    {% if selected_headline_font_size != blank %}{% assign headline_font_size = selected_headline_font_size %}{% endif %}
    {% if selected_desc_font_size != blank %}{% assign description_font_size = selected_desc_font_size %}{% endif %}
    {% if selected_button_font_size != blank %}{% assign button_font_size = selected_button_font_size %}{% endif %}
    {% if selected_button_radius != blank %}{% assign button_border_radius = selected_button_radius %}{% endif %}
    {% if selected_button_padding_vertical != blank %}{% assign button_padding_top = selected_button_padding_vertical %}{% assign button_padding_bottom = selected_button_padding_vertical %}{% endif %}
    {% if selected_button_padding_horizontal != blank %}{% assign button_padding_left = selected_button_padding_horizontal %}{% assign button_padding_right = selected_button_padding_horizontal %}{% endif %}
    {% if selected_button_padding != blank and selected_button_padding_vertical == blank and selected_button_padding_horizontal == blank %}{% assign button_padding_top = selected_button_padding %}{% assign button_padding_bottom = selected_button_padding %}{% assign button_padding_left = selected_button_padding %}{% assign button_padding_right = selected_button_padding %}{% endif %}
    {% if selected_headline_color != blank %}{% assign title_color_overlay = selected_headline_color %}{% endif %}
    {% if selected_desc_color != blank %}{% assign description_color_overlay = selected_desc_color %}{% endif %}
    {% if selected_button_bg != blank %}{% assign button_bg_overlay = selected_button_bg %}{% endif %}
    {% if selected_button_text_color != blank %}{% assign button_text_overlay = selected_button_text_color %}{% endif %}
    {% if selected_headline_color_below != blank %}{% assign title_color_below = selected_headline_color_below %}{% endif %}
    {% if selected_desc_color_below != blank %}{% assign description_color_below = selected_desc_color_below %}{% endif %}
    {% if selected_button_bg_below != blank %}{% assign button_bg_below = selected_button_bg_below %}{% endif %}
    {% if selected_button_text_color_below != blank %}{% assign button_text_below = selected_button_text_color_below %}{% endif %}
    {% if selected_text_alignment != blank %}{% assign content_alignment_desktop = selected_text_alignment %}{% assign content_alignment_mobile = selected_text_alignment %}{% endif %}
    
    <a href="{{ selected_target_url | default: '#' }}" class="scheduled-banner__link scheduled-banner__hero-link" style="--headline-size: {{ headline_font_size }}em; --desc-size: {{ description_font_size }}em; --btn-size: {{ button_font_size }}em; --btn-radius: {{ button_border_radius }}px; --btn-pad-t: {{ button_padding_top }}px; --btn-pad-r: {{ button_padding_right }}px; --btn-pad-b: {{ button_padding_bottom }}px; --btn-pad-l: {{ button_padding_left }}px; --title-overlay: {{ title_color_overlay }}; --desc-overlay: {{ description_color_overlay }}; --btn-bg-overlay: {{ button_bg_overlay }}; --btn-text-overlay: {{ button_text_overlay }}; --title-below: {{ title_color_below }}; --desc-below: {{ description_color_below }}; --btn-bg-below: {{ button_bg_below }}; --btn-text-below: {{ button_text_below }}; --headline-below-size: {{ headline_font_size | times: 0.8 }}em;{% if title_font != blank %} --title-font: {{ title_font.family }}, {{ title_font.fallback_families }}; --title-weight: {{ title_font.weight }}; --title-style: {{ title_font.style }};{% endif %}{% if description_font != blank %} --desc-font: {{ description_font.family }}, {{ description_font.fallback_families }}; --desc-weight: {{ description_font.weight }}; --desc-style: {{ description_font.style }};{% endif %}{% if button_text_uppercase %} --btn-uppercase: uppercase;{% else %} --btn-uppercase: none;{% endif %}">
      <div class="scheduled-banner__banner-container {% if mobile_content_below %}scheduled-banner__banner-container--mobile-below{% endif %}">
        {% if selected_desktop_banner != blank %}
          <div class="scheduled-banner__banner scheduled-banner__banner--desktop{% if banner_min_d != 'auto' %} scheduled-banner__banner--fixed-height{% endif %}"{% if banner_min_d != 'auto' %} style="min-height: {{ banner_min_d }}; --banner-fit: {{ img_fit_d }};"{% endif %}>
            {{ selected_desktop_banner | image_url: width: 1920 | image_tag: alt: selected_title, class: 'scheduled-banner__banner-img', loading: 'lazy' }}
            <div class="scheduled-banner__banner-content scheduled-banner__banner-content--desktop scheduled-banner__banner-content--v-{{ vertical_alignment }} scheduled-banner__banner-content--align-{{ content_alignment_desktop }}" style="--overlay-color: {{ overlay_color }}; --overlay-opacity: {{ overlay_opacity }};">
              <div class="scheduled-banner__content-inner">
                {% if selected_title != blank %}
                  <h2 class="scheduled-banner__title scheduled-banner__title--overlay">{{ selected_title }}</h2>
                {% endif %}
                {% if selected_description != blank %}
                  <p class="scheduled-banner__description scheduled-banner__description--overlay">{{ selected_description }}</p>
                {% endif %}
                {% if selected_button_text != blank %}
                  <span class="scheduled-banner__button scheduled-banner__button--overlay">{{ selected_button_text }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
        
        {% if selected_mobile_banner != blank %}
          <div class="scheduled-banner__banner scheduled-banner__banner--mobile{% if banner_min_m != 'auto' %} scheduled-banner__banner--fixed-height{% endif %}"{% if banner_min_m != 'auto' %} style="min-height: {{ banner_min_m }}; --banner-fit: {{ img_fit_m }};"{% endif %}>
            {{ selected_mobile_banner | image_url: width: 768 | image_tag: alt: selected_title, class: 'scheduled-banner__banner-img', loading: 'lazy' }}
            {% if mobile_content_below == false %}
              <div class="scheduled-banner__banner-content scheduled-banner__banner-content--mobile scheduled-banner__banner-content--v-{{ vertical_alignment }} scheduled-banner__banner-content--align-{{ content_alignment_mobile }}" style="--overlay-color: {{ overlay_color }}; --overlay-opacity: {{ overlay_opacity }};">
                <div class="scheduled-banner__content-inner">
                  {% if selected_title != blank %}
                    <h2 class="scheduled-banner__title scheduled-banner__title--overlay">{{ selected_title }}</h2>
                  {% endif %}
                  {% if selected_description != blank %}
                    <p class="scheduled-banner__description scheduled-banner__description--overlay">{{ selected_description }}</p>
                  {% endif %}
                  {% if selected_button_text != blank %}
                    <span class="scheduled-banner__button scheduled-banner__button--overlay">{{ selected_button_text }}</span>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
        
        {% if mobile_content_below %}
          <div class="scheduled-banner__content-below scheduled-banner__content-below--mobile-only scheduled-banner__content-below--align-{{ content_alignment_mobile }}">
            {% if selected_title != blank %}
              <h2 class="scheduled-banner__title scheduled-banner__title--below">{{ selected_title }}</h2>
            {% endif %}
            {% if selected_description != blank %}
              <p class="scheduled-banner__description scheduled-banner__description--below">{{ selected_description }}</p>
            {% endif %}
            {% if selected_button_text != blank %}
              <span class="scheduled-banner__button scheduled-banner__button--below">{{ selected_button_text }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </a>
  {% elsif show_announcement %}
    <div class="scheduled-banner__announcement scheduled-banner__announcement--bar" style="background-color: {{ selected_announcement_bg }}; color: {{ selected_announcement_color }};">
      {% if selected_announcement_link != blank %}
        <a href="{{ selected_announcement_link }}" class="scheduled-banner__announcement-link">{{ selected_announcement_text }}</a>
      {% else %}
        {{ selected_announcement_text }}
      {% endif %}
    </div>
  {% elsif show_collection %}
    {% assign coll_url = '/collections/' | append: selected_collection_handle %}
    {% assign coll_img = selected_collection_image | default: collections[selected_collection_handle].image %}
    {% assign coll_title = selected_title | default: collections[selected_collection_handle].title %}
    <a href="{{ coll_url }}" class="scheduled-banner__link">
      <div class="scheduled-banner__collection scheduled-banner__collection--banner{% if banner_min_d != 'auto' %} scheduled-banner__banner--fixed-height{% endif %}"{% if banner_min_d != 'auto' %} style="min-height: {{ banner_min_d }}; --banner-fit: {{ img_fit_d }};"{% endif %}>
        {% if coll_img != blank %}
          {{ coll_img | image_url: width: 1200 | image_tag: alt: coll_title, class: 'scheduled-banner__banner-img', loading: 'lazy' }}
        {% endif %}
        {% assign coll_overlay_color = selected_overlay_color | default: '#000000' %}
        {% assign coll_overlay_opacity = selected_overlay_opacity | default: 50 | divided_by: 100.0 %}
        <div class="scheduled-banner__banner-content" style="--overlay-color: {{ coll_overlay_color }}; --overlay-opacity: {{ coll_overlay_opacity }};">
          <h2 class="scheduled-banner__title">{{ coll_title }}</h2>
          {% if selected_description != blank %}<p class="scheduled-banner__description">{{ selected_description }}</p>{% endif %}
          {% if selected_button_text != blank %}<span class="scheduled-banner__button">{{ selected_button_text }}</span>{% endif %}
        </div>
      </div>
    </a>
  {% elsif show_countdown %}
    {% assign countdown_link = selected_countdown_link | default: '#' %}
    <a href="{{ countdown_link }}" class="scheduled-banner__link">
      <div id="countdown-{{ block.id | default: 'main' }}" class="scheduled-banner__countdown scheduled-banner__countdown--bar{% if banner_min_d != 'auto' %} scheduled-banner__countdown--fixed-height{% endif %}" style="background-color: {{ selected_countdown_bg }}; color: {{ selected_countdown_text_color }};{% if banner_min_d != 'auto' %} min-height: {{ banner_min_d }}; --banner-fit: {{ img_fit_d }};{% endif %}">
        {% if selected_countdown_bg_img != blank %}
          {% assign cd_bg_opacity = selected_overlay_opacity | default: 30 | divided_by: 100.0 %}
          <div class="scheduled-banner__countdown-bg" style="opacity: {{ cd_bg_opacity }};">
            {{ selected_countdown_bg_img | image_url: width: 1200 | image_tag: alt: '', loading: 'lazy', class: 'scheduled-banner__countdown-bg-img' }}
          </div>
        {% endif %}
        <div class="scheduled-banner__countdown-inner">
          {% if selected_countdown_headline != blank %}<h2 class="scheduled-banner__countdown-headline">{{ selected_countdown_headline }}</h2>{% endif %}
          <div class="scheduled-banner__countdown-timer" data-target="{{ selected_countdown_target }}">
            <span data-days>0</span>d <span data-hours>0</span>h <span data-mins>0</span>m <span data-secs>0</span>s
          </div>
          {% if selected_countdown_subtext != blank %}<p class="scheduled-banner__countdown-subtext">{{ selected_countdown_subtext }}</p>{% endif %}
          {% if selected_countdown_btn != blank %}<span class="scheduled-banner__button">{{ selected_countdown_btn }}</span>{% endif %}
        </div>
      </div>
    </a>
  {% elsif show_iwt %}
    {% assign iwt_link = selected_iwt_link | default: '#' %}
    <div class="scheduled-banner__iwt scheduled-banner__iwt--{{ selected_iwt_layout }}">
      {% if selected_iwt_layout == 'image_right' %}
        <div class="scheduled-banner__iwt-text">
          {% if selected_title != blank %}<h2 class="scheduled-banner__title">{{ selected_title }}</h2>{% endif %}
          {% if selected_description != blank %}<p class="scheduled-banner__description">{{ selected_description }}</p>{% endif %}
          {% if selected_button_text != blank %}<a href="{{ iwt_link }}" class="scheduled-banner__button">{{ selected_button_text }}</a>{% endif %}
        </div>
      {% endif %}
      <div class="scheduled-banner__iwt-img">
        {{ selected_iwt_image | image_url: width: 800 | image_tag: alt: selected_title, loading: 'lazy', class: 'scheduled-banner__iwt-img-el' }}
      </div>
      {% if selected_iwt_layout == 'image_left' %}
        <div class="scheduled-banner__iwt-text">
          {% if selected_title != blank %}<h2 class="scheduled-banner__title">{{ selected_title }}</h2>{% endif %}
          {% if selected_description != blank %}<p class="scheduled-banner__description">{{ selected_description }}</p>{% endif %}
          {% if selected_button_text != blank %}<a href="{{ iwt_link }}" class="scheduled-banner__button">{{ selected_button_text }}</a>{% endif %}
        </div>
      {% endif %}
    </div>
  {% elsif show_video %}
    {% assign vid_src = selected_video_url %}
    {% if vid_src == blank and selected_video_file != blank and selected_video_file_ref != blank %}
      {% assign vid_ref = selected_video_file_ref %}
      {% if vid_ref.sources != blank %}
        {% assign vid_src = vid_ref.sources[0].url %}
      {% endif %}
    {% endif %}
    {% if vid_src != blank %}
      <div class="scheduled-banner__video-wrap"{% if banner_min_d != 'auto' %} style="min-height: {{ banner_min_d }}; --banner-fit: {{ img_fit_d }};"{% endif %}>
        <video class="scheduled-banner__video" autoplay muted loop playsinline>
          <source src="{{ vid_src }}" type="video/mp4">
        </video>
        <div class="scheduled-banner__video-overlay" style="background-color: rgba(0,0,0,{{ selected_video_overlay | divided_by: 100.0 }});">
          {% if selected_title != blank %}<h2 class="scheduled-banner__video-title">{{ selected_title }}</h2>{% endif %}
          {% if selected_description != blank %}<p class="scheduled-banner__video-desc">{{ selected_description }}</p>{% endif %}
          {% if selected_button_text != blank and selected_target_url != blank %}<a href="{{ selected_target_url }}" class="scheduled-banner__button">{{ selected_button_text }}</a>{% endif %}
        </div>
      </div>
    {% endif %}
  {% elsif show_promo %}
    <a href="{{ selected_promo_url | default: '#' }}" class="scheduled-banner__link">
      <div class="scheduled-banner__promo scheduled-banner__promo--card">
        <div class="scheduled-banner__promo-img-wrap{% if banner_min_d != 'auto' %} scheduled-banner__promo-img-wrap--fixed{% endif %}"{% if banner_min_d != 'auto' %} style="min-height: {{ banner_min_d }}; --banner-fit: {{ img_fit_d }};"{% endif %}>
