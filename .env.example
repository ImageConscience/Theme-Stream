# Required for Prisma (PostgreSQL). Railway injects this when Postgres is linked.
# For local dev: use a local Postgres or a free hosted DB (e.g. Neon, Supabase).
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Shopify app (from Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.up.railway.app
SCOPES=read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,unauthenticated_read_metaobjects,read_files,write_files,read_content,write_content

# Managed app pricing (Partner Dashboard — plans "starter" and "streamer")
# App handle = URL slug of the app in Partners (used in admin billing URL).
SHOPIFY_APP_HANDLE=your-app-handle
# Optional: exact AppSubscription.name values from Shopify if they differ from defaults
# MANAGED_PLAN_MATCH_STARTER=starter,Starter
# MANAGED_PLAN_MATCH_STREAMER=streamer,Streamer
BILLING_ENABLED=true

# Support & legal (for privacy policy, support page, App Store listing)
SUPPORT_EMAIL=support@imageconscience.com

# Production
NODE_ENV=production
