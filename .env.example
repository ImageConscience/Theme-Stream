# Required for Prisma (PostgreSQL). Railway injects this when Postgres is linked.
# For local dev: use a local Postgres or a free hosted DB (e.g. Neon, Supabase).
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Shopify app (from Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.up.railway.app
SCOPES=read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,unauthenticated_read_metaobjects,read_files,write_files,read_content,write_content

# Billing (Theme Stream plans)
BILLING_PLAN_STARTER_NAME=Starter
BILLING_PRICE_STARTER=9
BILLING_PLAN_STREAMER_NAME=Streamer
BILLING_PRICE_STREAMER=29
BILLING_PLAN_STREAMER_PLUS_NAME=Streamer Plus
BILLING_PRICE_STREAMER_PLUS=49
BILLING_CURRENCY=USD
BILLING_INTERVAL=EVERY_30_DAYS
BILLING_TRIAL_DAYS=7
BILLING_ENABLED=true

# Production
NODE_ENV=production
